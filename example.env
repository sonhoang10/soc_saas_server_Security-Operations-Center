# ==============================================================================
# FLUX SOC - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# INSTRUCTIONS: 
# 1. Copy this file and rename it to `.env`
# 2. Replace the placeholders (e.g., <YOUR_...>) with your actual server IPs and passwords.
# WARNING: Never commit your actual `.env` file to version control.
# ==============================================================================

# ------------------------------------------
# 1. CORE SERVER CONFIGURATION
# ------------------------------------------
# The public or private IP of the Main SOC Server hosting the APIs and Dashboard
MAIN_SERVER=<IP_MAIN_HERE>

# ------------------------------------------
# 2. MESSAGE BROKER (APACHE KAFKA)
# ------------------------------------------
# IP address and port of the Kafka KRaft server
KAFKA_SERVER=<IP_KAFKA_HERE>
KAFKA_PORT=9092
KAFKA_TOPIC=soc-raw-logs

# ------------------------------------------
# 3. TIME-SERIES DATABASE (CLICKHOUSE)
# ------------------------------------------
# Configuration for high-throughput log storage
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASS=<YOUR_CLICKHOUSE_PASSWORD_HERE>

# ------------------------------------------
# 4. SECURITY & CORS CONFIGURATION
# ------------------------------------------
# Replace placeholders with actual IPs to allow cross-origin requests.
# Port 8000 is for backend, port 8080 is for frontend.
ALLOWED_ORIGINS=http://localhost:8000,http://<IP_KAFKA_HERE>,http://<IP_MAIN_HERE>:8080,http://<IP_MAIN_HERE>

# ------------------------------------------
# 5. RELATIONAL DATABASE (POSTGRESQL)
# ------------------------------------------
# Configuration for Users, Teams, and Server Metadata
PG_USER=soc_admin
PG_PASS=<YOUR_POSTGRES_PASSWORD_HERE>
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=soc_main_db

# IMPORTANT: Connection string for SQLAlchemy (Alembic Migrations)
# Python does NOT natively interpolate ${PG_USER} in .env files.
# You MUST write out the full string manually.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://soc_admin:<YOUR_POSTGRES_PASSWORD_HERE>@127.0.0.1:5432/soc_main_db

# ------------------------------------------
# 6. LOGIC ENGINE & ACTIVE DEFENDER
# ------------------------------------------
# Secret key used for internal authentication between Logic Engine and Client Agents.
# Generate a strong, random string for production.
INTERNAL_API_KEY=<GENERATE_A_RANDOM_SECRET_KEY_HERE>

# Endpoint where the Logic Engine pushes processed alerts to the Web Backend
WEB_BACKEND_URL=http://127.0.0.1:8000/api/alerts

# Port used by the Flux Defender Agent on the client servers
AGENT_PORT=8001

# Comma-separated IPs that will NEVER be blocked by the Active Defender
# Highly recommended to whitelist your Main Server IP and your personal VPN/Home IP.
WHITELIST_IPS=127.0.0.1,<IP_MAIN_HERE>

# --- THREAT DETECTION THRESHOLDS (Sliding Window Algorithm) ---
# Brute-force/General failure tracking window (seconds)
TIME_WINDOW_SECONDS=60
# Max failures allowed within the TIME_WINDOW_SECONDS before triggering a ban
MAX_FAILURES=5

# DDoS/Flood tracking window (seconds)
DDOS_WINDOW_SECONDS=10
# Max requests allowed within the DDOS_WINDOW_SECONDS before triggering a ban
DDOS_MAX_REQUESTS=100
